 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Resume Screening Demo\n",
    "\n",
    "This notebook demonstrates skill extraction, similarity scoring, and candidate ranking using the sample dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "import sys\n",
    "\n",
    "sys.path.append(\"src\")\n",
    "\n",
    "from io_utils import load_resumes_from_csv\n",
    "from job_parser import parse_job_skills\n",
    "from scoring import compute_tfidf_similarity, top_job_terms, overlap_terms\n",
    "from skills import extract_skills, load_skill_patterns, skill_gap\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "job_text = Path(\"data/job_description.txt\").read_text(encoding=\"utf-8\")\n",
    "resumes_path = Path(\"Resume.csv\") if Path(\"Resume.csv\").exists() else Path(\"data/resumes.csv\")\n",
    "resumes_df = load_resumes_from_csv(resumes_path)\n",
    "patterns = load_skill_patterns(\"data/skills.json\")\n",
    "\n",
    "required_skills, nice_skills = parse_job_skills(job_text, patterns)\n",
    "similarities, vectorizer, tfidf = compute_tfidf_similarity(job_text, resumes_df[\"text\"].tolist())\n",
    "job_terms = top_job_terms(vectorizer, tfidf, top_n=8)\n",
    "\n",
    "required_skills, nice_skills, job_terms"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rows = []\n",
    "for idx, row in resumes_df.iterrows():\n",
    "    found, _ = extract_skills(row[\"text\"], patterns)\n",
    "    matched_req, missing_req = skill_gap(required_skills, found)\n",
    "    matched_nice, missing_nice = skill_gap(nice_skills, found)\n",
    "\n",
    "    req_score = len(matched_req) / len(required_skills) if required_skills else 0\n",
    "    nice_score = len(matched_nice) / len(nice_skills) if nice_skills else 0\n",
    "    skill_score = 0.7 * req_score + 0.3 * nice_score if nice_skills else req_score\n",
    "\n",
    "    similarity = float(similarities[idx])\n",
    "    total = 0.6 * similarity + 0.4 * skill_score\n",
    "\n",
    "    resume_vec = tfidf[idx + 1: idx + 2]\n",
    "    overlap = overlap_terms(resume_vec, job_terms, vectorizer)\n",
    "\n",
    "    rows.append({\n",
    "        \"name\": row[\"name\"],\n",
    "        \"total_score\": round(total, 4),\n",
    "        \"similarity\": round(similarity, 4),\n",
    "        \"skill_score\": round(skill_score, 4),\n",
    "        \"matched_required\": \", \\".join(matched_req),\n",
    "        \"missing_required\": \", \\".join(missing_req),\n",
    "        \"matched_nice\": \", \\".join(matched_nice),\n",
    "        \"missing_nice\": \", \\".join(missing_nice),\n",
    "        \"job_terms_overlap\": \", \\".join(overlap),\n",
    "    })\n",
    "\n",
    "pd.DataFrame(rows).sort_values(\"total_score\", ascending=False)"
   ]
  }
 ],
